{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the StreetPaws application.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile photo URL." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role in the application." }
      },
      "required": ["displayName", "email", "role"]
    },
    "Pet": {
      "title": "Pet",
      "description": "A pet listed for adoption or rescue.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The pet's name." },
        "type": { "type": "string", "enum": ["Dog", "Cat", "Bird", "Rat", "Other"], "description": "The type of animal." },
        "age": { "type": "string", "description": "The pet's age." },
        "location": { "type": "string", "description": "The location where the pet was found." },
        "description": { "type": "string", "description": "A description of the pet." },
        "imageUrl": { "type": "string", "description": "A base64 or URL of the pet's photo." },
        "contactNumber": { "type": "string", "description": "The contact number for the reporter." },
        "contactName": { "type": "string", "description": "The name of the reporter." },
        "urgency": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"], "description": "The urgency level of the rescue." },
        "traits": { "type": "string", "description": "Personality traits of the pet." },
        "postedAt": { "type": "object", "description": "The timestamp when the pet was listed." },
        "cheers": { "type": "number", "description": "The number of cheers the pet has received." },
        "comments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "createdAt": { "type": "object" },
              "author": { "type": "string" },
              "authorUid": { "type": "string" },
              "authorPhotoUrl": { "type": "string" }
            }
          }
        },
        "authorUid": { "type": "string", "description": "The UID of the user who posted the pet." }
      },
      "required": ["name", "type", "location", "description", "imageUrl", "contactNumber", "contactName", "urgency", "postedAt", "authorUid"]
    },
    "Story": {
      "title": "Story",
      "description": "A success story shared by a user.",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "The content of the story." },
        "imageUrl": { "type": "string", "description": "An image associated with the story." },
        "author": { "type": "string", "description": "The name of the author." },
        "authorUid": { "type": "string", "description": "The UID of the author." },
        "createdAt": { "type": "object", "description": "The timestamp when the story was created." }
      },
      "required": ["content", "imageUrl", "author", "authorUid", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/pets/{petId}": {
      "schema": "Pet",
      "description": "Pet listing documents."
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "Success story documents."
    }
  }
}
